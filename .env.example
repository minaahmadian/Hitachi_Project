# API Key (Required for LLM nodes — create at https://console.groq.com/keys)
# Copy this file:  cp .env.example .env   then edit .env (never commit .env)
GROQ_API_KEY=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

# Chat model (default: llama-3.1-8b-instant)
# GROQ_CHAT_MODEL=llama-3.1-8b-instant

# Groq SDK HTTP retries on 429 inside one request. Keep 0 for fast fail; app retries separately.
# GROQ_MAX_RETRIES=0

# Cap JSON completion length (saves TPM on ~6000/min free tier)
# GROQ_MAX_OUTPUT_TOKENS=900

# Seconds between Auditor → Detective → Lead Assessor (35 default; increase if 429 persists)
GROQ_LLM_CALL_DELAY_SEC=35

# After 429, sleep (using API hint) and retry the same invoke (default 3)
GROQ_INVOKE_RATE_LIMIT_RETRIES=3

# Lead Assessor: JSON blob budgets (characters).
# Safety note: core/blob_compaction.py performs priority-aware compaction —
#   verdict_per_anomaly is always serialised as one-line digests and is
#   NEVER dropped. Only low-priority metadata (citations, fingerprints,
#   evidence_chain_text, …) is shed to fit. If anything is dropped the
#   '[truncated]' marker is added and the LLM is instructed to treat it
#   as a safety signal.  You can safely raise these values if your Groq
#   tier allows larger requests.
LEAD_ASSESSOR_PRE_ISA_CHARS=4000
LEAD_ASSESSOR_REPORT_CHARS=1200
LEAD_ASSESSOR_AUTH_CHARS=700

# Formal Auditor: document excerpt sent to Groq (paragraphs first, then tables; default 12000)
# AUDITOR_MAX_DOC_CHARS=12000

# Context Detective: matcher / derogation / email caps
# Matcher JSON is now priority-aware too (anomaly_digests never dropped).
# DETECTIVE_MATCHER_JSON_CHARS=2600
# DETECTIVE_DEROG_JSON_CHARS=1400
# DETECTIVE_EMAIL_CHARS=3200

# Use hash embedder for regulatory RAG (no extra Groq TPM). Omit or set groq if you need semantic embeddings.
# EMBEDDING_PROVIDER=hash

# Qdrant Configuration
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=documents

# Embedding Configuration (Groq)
EMBEDDING_MODEL=nomic-embed-text

# Processing Configuration
CHUNK_SIZE=500
CHUNK_OVERLAP=50

# Requirements trace CSV (default data/requirements_trace.csv). From RSSOM:
#   Replace file:  python -m core.rssom_requirements_trace --docx data/RSSOM_APCS_FIT.docx --out data/requirements_trace.csv
#   Merge/enrich:  ... same ... --merge   (keeps manual-only rows & verification_status; updates titles)
