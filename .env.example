# API Key (Required)
GROQ_API_KEY=your_groq_key_here

# Chat model (default: llama-3.1-8b-instant). Lower tiers: watch TPM and request size (413/429).
# GROQ_CHAT_MODEL=llama-3.1-8b-instant

# Groq SDK retries on 429 (with sleep). Default 0 = fail fast so agents use fallbacks; use 2 to retry.
# GROQ_MAX_RETRIES=0

# Seconds to wait between LLM calls (Auditor → Detective → Lead Assessor). Helps stay under low TPM tiers.
GROQ_LLM_CALL_DELAY_SEC=20

# Lead Assessor prompt size (chars). Lower = fewer tokens / fewer 413/429 bursts.
LEAD_ASSESSOR_PRE_ISA_CHARS=2500
LEAD_ASSESSOR_REPORT_CHARS=1200
LEAD_ASSESSOR_AUTH_CHARS=1000

# Qdrant Configuration
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=documents

# Embedding Configuration (Groq)
EMBEDDING_MODEL=nomic-embed-text

# Processing Configuration
CHUNK_SIZE=500
CHUNK_OVERLAP=50