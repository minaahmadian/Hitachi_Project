# API Key (Required)
GROQ_API_KEY=your_groq_key_here

# Chat model (default: llama-3.1-8b-instant). Lower tiers: watch TPM and request size (413/429).
# GROQ_CHAT_MODEL=llama-3.1-8b-instant

# Groq SDK retries on 429 (with sleep). Default 0 = fail fast so agents use fallbacks; use 2 to retry.
# GROQ_MAX_RETRIES=0

# Lead Assessor prompt size (chars). Reduce if Groq returns 413 Payload Too Large; increase if your tier allows.
# LEAD_ASSESSOR_PRE_ISA_CHARS=4000
# LEAD_ASSESSOR_REPORT_CHARS=1800
# LEAD_ASSESSOR_AUTH_CHARS=1500

# Qdrant Configuration
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=documents

# Embedding Configuration (Groq)
EMBEDDING_MODEL=nomic-embed-text

# Processing Configuration
CHUNK_SIZE=500
CHUNK_OVERLAP=50